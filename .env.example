NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Yalnızca sunucuda kullanılır; tarayıcıya veya Git'e göndermeyin.
SUPABASE_SECRET_KEY=your-secret-or-service-role-key

# Cloudflare R2 (isteğe bağlı; tanımlandığında anı medyası R2'ye yüklenir).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=love-media

# Standart Web Push / Safari için VAPID anahtarları.
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=https://your-production-domain.example

# Yalnızca yerel geliştirme ortamında, isteğe bağlı hızlı demo girişi için.
# Bu hesapların Supabase'de önceden oluşturulmuş ve bir çifte katılmış
# (profiles satırına sahip) olması gerekir. Production'da kullanılmaz.
DEV_DEMO_OWNER_EMAIL=
DEV_DEMO_OWNER_PASSWORD=
DEV_DEMO_PARTNER_EMAIL=
DEV_DEMO_PARTNER_PASSWORD=
